# Expo + pnpm monorepo: React Native autolinking and Metro expect a flat-ish
# node_modules, and the symlinked pnpm layout breaks bare imports injected by
# tooling (e.g. NativeWind's react-native-css-interop/jsx-runtime). Expo's
# official monorepo guide recommends a hoisted linker for pnpm.
node-linker=hoisted
