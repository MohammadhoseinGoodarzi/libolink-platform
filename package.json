{
  "name": "libolink",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=web",
    "dev:mobile": "turbo run dev --filter=mobile",
    "build": "turbo run build",
    "lint": "biome check .",
    "format": "biome format --write .",
    "type-check": "turbo run type-check"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "turbo": "2.9.18",
    "typescript": "5.9.3"
  }
}
